{
  "name": "MVP full build and quest loop",
  "goal": "Build and fully upgrade the three town buildings, let heroes arrive, go on quests off-screen, and return after completing them.",
  "seed": 42,
  "max_ticks": 0,
  "commands": [
    {"cmd": "set_gold", "value": 180},
    {"cmd": "place_building", "type": "tavern", "x": 0, "z": 0},
    {"cmd": "place_building", "type": "weapons_shop", "x": 3, "z": 0},
    {"cmd": "place_building", "type": "temple", "x": -3, "z": 0},
    {"cmd": "upgrade_building", "type": "tavern"},
    {"cmd": "upgrade_building", "type": "tavern"},
    {"cmd": "upgrade_building", "type": "weapons_shop"},
    {"cmd": "upgrade_building", "type": "weapons_shop"},
    {"cmd": "upgrade_building", "type": "temple"},
    {"cmd": "upgrade_building", "type": "temple"},
    {"cmd": "step_ticks", "n": 420},
    {"cmd": "set_building_output_mode", "type": "tavern"},
    {"cmd": "step_ticks", "n": 180},
    {"cmd": "accept_quest"},
    {"cmd": "set_building_output_mode", "type": "weapons_shop"},
    {"cmd": "set_building_output_mode", "type": "temple"},
    {"cmd": "step_ticks", "n": 2400}
  ],
  "assertions": [
    {"assert": "building_exists", "type": "tavern"},
    {"assert": "building_exists", "type": "weapons_shop"},
    {"assert": "building_exists", "type": "temple"},
    {"assert": "building_level_eq", "type": "tavern", "value": 3},
    {"assert": "building_level_eq", "type": "weapons_shop", "value": 3},
    {"assert": "building_level_eq", "type": "temple", "value": 3},
    {"assert": "event_type_seen", "value": "hero_started_quest"},
    {"assert": "event_type_seen", "value": "hero_departed_for_quest"},
    {"assert": "event_type_seen", "value": "hero_completed_quest"},
    {"assert": "event_type_seen", "value": "hero_heading_home"},
    {"assert": "event_type_seen", "value": "hero_returned_from_quest"}
  ]
}
