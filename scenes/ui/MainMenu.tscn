[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/ui/MainMenu.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/ui/ScreenFade.tscn" id="2"]
[ext_resource type="Script" path="res://scripts/ui/MenuHost.gd" id="3"]

[sub_resource type="StyleBoxFlat" id="1"]
bg_color = Color(0.1, 0.13, 0.11, 0.92)
corner_radius_top_left = 16
corner_radius_top_right = 16
corner_radius_bottom_right = 16
corner_radius_bottom_left = 16

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.16, 0.22, 0.16, 1)

[node name="Center" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Center"]
theme_override_constants/separation = 10

[node name="Panel" type="PanelContainer" parent="Center/VBox"]
theme_override_styles/panel = SubResource("1")

[node name="Margin" type="MarginContainer" parent="Center/VBox/Panel"]
theme_override_constants/margin_left = 28
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 28
theme_override_constants/margin_bottom = 24

[node name="Inner" type="VBoxContainer" parent="Center/VBox/Panel/Margin"]
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Center/VBox/Panel/Margin/Inner"]
text = "QuestTown"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 28

[node name="Subtitle" type="Label" parent="Center/VBox/Panel/Margin/Inner"]
text = "Town-building prototype"
horizontal_alignment = 1

[node name="NewButton" type="Button" parent="Center/VBox/Panel/Margin/Inner"]
text = "New Town"

[node name="LoadButton" type="Button" parent="Center/VBox/Panel/Margin/Inner"]
text = "Load Save"

[node name="OptionsButton" type="Button" parent="Center/VBox/Panel/Margin/Inner"]
text = "Options"

[node name="QuitButton" type="Button" parent="Center/VBox/Panel/Margin/Inner"]
text = "Quit"

[node name="StatusLabel" type="Label" parent="Center/VBox"]
text = "No save file detected yet."
horizontal_alignment = 1

[node name="MenuHost" type="Control" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("3")

[node name="ScreenFade" parent="." instance=ExtResource("2")]

[connection signal="pressed" from="Center/VBox/Panel/Margin/Inner/NewButton" to="." method="_on_new_button_pressed"]
[connection signal="pressed" from="Center/VBox/Panel/Margin/Inner/LoadButton" to="." method="_on_load_button_pressed"]
[connection signal="pressed" from="Center/VBox/Panel/Margin/Inner/OptionsButton" to="." method="_on_options_button_pressed"]
[connection signal="pressed" from="Center/VBox/Panel/Margin/Inner/QuitButton" to="." method="_on_quit_button_pressed"]
