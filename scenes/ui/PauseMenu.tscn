[gd_scene load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/ui/PauseMenu.gd" id="1"]
[ext_resource type="Script" path="res://scripts/ui/MenuHost.gd" id="2"]
[ext_resource type="PackedScene" path="res://scenes/ui/ScreenFade.tscn" id="3"]

[sub_resource type="StyleBoxFlat" id="1"]
bg_color = Color(0.06, 0.08, 0.09, 0.94)
corner_radius_top_left = 14
corner_radius_top_right = 14
corner_radius_bottom_right = 14
corner_radius_bottom_left = 14

[node name="PauseMenu" type="CanvasLayer"]
script = ExtResource("1")

[node name="Backdrop" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.45)

[node name="Center" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="Center"]
theme_override_styles/panel = SubResource("1")

[node name="Margin" type="MarginContainer" parent="Center/Panel"]
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="VBox" type="VBoxContainer" parent="Center/Panel/Margin"]
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Center/Panel/Margin/VBox"]
text = "Paused"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 24

[node name="ResumeButton" type="Button" parent="Center/Panel/Margin/VBox"]
text = "Resume"

[node name="SaveButton" type="Button" parent="Center/Panel/Margin/VBox"]
text = "Save Town"

[node name="LoadButton" type="Button" parent="Center/Panel/Margin/VBox"]
text = "Load Town"

[node name="OptionsButton" type="Button" parent="Center/Panel/Margin/VBox"]
text = "Options"

[node name="MainMenuButton" type="Button" parent="Center/Panel/Margin/VBox"]
text = "Main Menu"

[node name="MenuHost" type="Control" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("2")

[node name="ScreenFade" parent="." instance=ExtResource("3")]

[connection signal="pressed" from="Center/Panel/Margin/VBox/ResumeButton" to="." method="_on_resume_button_pressed"]
[connection signal="pressed" from="Center/Panel/Margin/VBox/SaveButton" to="." method="_on_save_button_pressed"]
[connection signal="pressed" from="Center/Panel/Margin/VBox/LoadButton" to="." method="_on_load_button_pressed"]
[connection signal="pressed" from="Center/Panel/Margin/VBox/OptionsButton" to="." method="_on_options_button_pressed"]
[connection signal="pressed" from="Center/Panel/Margin/VBox/MainMenuButton" to="." method="_on_main_menu_button_pressed"]
